@startuml AgenticWorkflow_UseCase
left to right direction

actor User
actor "LLM System" as LLM

package "AgenticWorkflow System" {
    usecase "Create Agent" as UC1
    usecase "Add Workflow Step" as UC2
    usecase "Configure Step" as UC3
    usecase "Run Workflow" as UC4
    usecase "Execute Step" as UC5
    usecase "Validate Input" as UC6
    usecase "Handle Errors" as UC7
    usecase "Load Agent from File" as UC8
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC8

UC2 --> UC6 : includes
UC3 --> UC6 : includes
UC4 --> UC5 : includes
UC5 --> LLM : sends prompt
LLM --> UC5 : returns response

UC4 --> UC7 : includes
UC5 --> UC7 : includes

UC8 --> UC6 : includes

note right of UC2
  Step name must be unique
  Step must not be null
end note

note right of UC5
  Handles StructuredOutput
end note

note right of UC7
  Catches WorkflowFormatException
  Logs errors
end note
@enduml