@startuml sequence-success
skinparam defaultFontName "JetBrains Mono"

autonumber
actor Simulation
participant Guild
participant Adventurer
participant Quest
participant Weapon
participant Monster

Simulation -> Guild: runSimulation()
Guild -> Quest: attemptQuest(adventurer)
Quest -> Adventurer: getStrongestWeapon()
Adventurer --> Quest: weapon

loop While monster.health > 0 and adventurer.health > 0
  Quest -> Adventurer: attack(monster)
  Adventurer -> Weapon: performAttack(monster)
  Weapon -> Monster: takeDamage(weaponDamage, bypassArmor?)
  Adventurer -> Monster: takeDamage(basePower + rank, false)

  alt Monster survives
    Quest -> Monster: attack(adventurer)
    Monster -> Adventurer: takeDamage(strength)
  end
end

Quest -> Adventurer: gainExperience(rewardXp)
Quest --> Guild: true (complete)
Guild --> Simulation: success

@enduml
