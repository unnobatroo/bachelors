interface PricingStrategy {
    + calculateFee(tripRecord: TripRecord): float
}

class StandardStrategy <<singleton>> {
    + getInstance(): StandardStrategy
    + calculateFee(tripRecord: TripRecord): float
}

note bottom of StandardStrategy
    return tripRecord.getDistKm() * tripRecord.getVehicle().getMultiplier();
end note

class EcoPeakStrategy <<singleton>> {
    + getInstance(): EcoPeakStrategy
    + calculateFee(tripRecord: TripRecord): float
}

note bottom of EcoPeakStrategy
    if peak hours:
        return distKm * multiplier * 1.5f
    else:
        return distKm * multiplier * vehicle.getOffPeakMultiplier()
end note

class GreenWeekendStrategy <<singleton>> {
    + getInstance(): GreenWeekendStrategy
    + calculateFee(tripRecord: TripRecord): float
}

note bottom of GreenWeekendStrategy
    @Override public float calculateFee(TripRecord rec) {
        java.time.DayOfWeek day = rec.getDateTime().getDayOfWeek();
        if (day == java.time.DayOfWeek.SATURDAY || day == java.time.DayOfWeek.SUNDAY) {
            return rec.getDistKm() * rec.getVehicle().getMultiplier() * rec.getVehicle().getWeekendMultiplier();
        } else {
            return rec.getDistKm() * rec.getVehicle().getMultiplier();
        }
    }
end note

HighwaySystem "1" *-- "0..*" TollSegment
HighwaySystem "1" o-- "0..*" Vehicle
HighwaySystem "1" --> "0..1" PricingStrategy : uses

TollSegment "1" *-- "0..*" TripRecord
TripRecord "*" --> "1" Vehicle

Vehicle <|-- Motorcycle
Vehicle <|-- PassengerCar
Vehicle <|-- HeavyTruck

PricingStrategy <|.. GreenWeekendStrategy
PricingStrategy <|.. StandardStrategy
PricingStrategy <|.. EcoPeakStrategy

@enduml