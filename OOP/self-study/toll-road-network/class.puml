@startuml class

skinparam defaultFontName "JetBrains Mono"

class HighwaySystem {
    - {static} name: String
    - {static} tollSegments: List<TollSegment>
    - {static} regVehicles: HashMap<Vehicle, LocalDateTime>
    - {static} pricingStrategy: PricingStrategy

    + getName(): String
    + setName(name: String): void
    + {static} addVehicle(vehicle: Vehicle): void
    + {static} getPricingStrategy(): PricingStrategy
    + {static} setPricingStrategy(pricingStrategy: PricingStrategy): void
    + {static} getMostProfitableSegment(): TollSegment
    + HighwaySystem(name: String)
    + HighwaySystem(name: String, pricingStrategy: PricingStrategy)
}

note right of HighwaySystem::getMostProfitableSegment
    return tollSegments.stream()
                .max(Comparator.comparingDouble(seg -> seg.getTotalRevenue(pricingStrategy)))
                .orElse(null);
end note

class TollSegment {
    - name: String
    - tripRecords: List<TripRecord>

    + getName(): String
    + setName(name: String): void
    + getTotalRevenue(strategy: PricingStrategy): float
    + hadHeavyTruckTripDuringPeak(): boolean
    + isStrictlyEcoFriendly(): boolean
    + TollSegment(name: String)
    + TollSegment(name: String, tripRecords: List<TripRecord>)
}

note right of TollSegment::getTotalRevenue
    float total = 0;
    for (TripRecord rec : tripRecords) {
        total += rec.getTollFee(strategy);
    }
    return total;
end note

note right of TollSegment::isStrictlyEcoFriendly
    for (TripRecord rec : tripRecords) {
        int hour = rec.getDateTime().getHour();
        boolean isPeak = (hour >= 7 && hour < 9) || (hour >= 16 && hour < 18);
        if (isPeak && rec.getVehicle().isHeavyWeight()) {
            return true;
        }
    }
    return false;
end note

class TripRecord {
    - distKm: float
    - dateTime: java.time.LocalDateTime
    - vehicle: Vehicle

    + getDistKm(): float
    + getDateTime(): java.time.LocalDateTime
    + getVehicle(): Vehicle
    + getTollFee(strategy: PricingStrategy): float
    + TripRecord(distKm: float, vehicle: Vehicle)
}

note right of TripRecord::getTollFee
    return strategy.calculateFee(this);
end note

abstract class Vehicle {
    - licensePlate: String

    # Vehicle(licensePlate: String)
    + getLicensePlate(): String
    + {abstract} getMultiplier(): int
    + getOffPeakMultiplier(): float
    + getWeekendMultiplier(): float
    + isHeavyWeight(): boolean
}

note left of Vehicle::getOffPeakMultiplier
    return 1.0f;
end note

note left of Vehicle::getWeekendMultiplier
    return 1.0f;
end note

note left of Vehicle::isHeavyWeight
    return false;
end note

